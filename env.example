# ============================================================
# AI Support Chatbot — Environment Variables
# Multi-Account AI Failover Configuration
# ============================================================

# ─── Cloudflare Account IDs ─────────────────────────────────
# Get from: https://dash.cloudflare.com/ → Overview → Account ID
CF_ACCOUNT_ID=your_primary_account_id

# ─── Multi-Account AI Failover (Optional) ───────────────────
# Create API tokens at: https://dash.cloudflare.com/profile/api-tokens
# Token needs: AI Run permissions
CF_ACCOUNT_ID_2=your_fallback_account_id_2
CF_API_TOKEN_2=your_fallback_api_token_2
CF_ACCOUNT_ID_3=your_fallback_account_id_3
CF_API_TOKEN_3=your_fallback_api_token_3

# ─── D1 Database ────────────────────────────────────────────
# Created with: wrangler d1 create support-db
CF_D1_DATABASE_ID=your_d1_database_id_here

# ─── KV Namespace ───────────────────────────────────────────
# Created with: wrangler kv:namespace create SESSIONS
CF_KV_NAMESPACE_ID=your_kv_namespace_id_here
CF_KV_PREVIEW_NAMESPACE_ID=your_kv_preview_id_here

# ─── Telegram Bot (Optional) ────────────────────────────────
# Bot token from: @BotFather on Telegram
# Chat ID from: @userinfobot on Telegram
TG_BOT_TOKEN=your_telegram_bot_token
TG_CHAT_ID=your_telegram_chat_id

# ─── Admin Security ─────────────────────────────────────────
# Generate with: openssl rand -hex 32
ADMIN_SECRET=your_strong_admin_secret_32_chars_plus

# ─── Worker URL (After deployment) ──────────────────────────
WORKER_API_URL=https://your-worker-name.your-subdomain.workers.dev